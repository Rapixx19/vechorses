{
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:changed": "jest --onlyChanged",
    "test:integration": "jest --testPathPattern=integration",
    "test:coverage": "jest --coverage",
    "qa": "npm run type-check && npm run lint && npm run test:coverage",
    "pre-push": "./scripts/smart-test.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.3.2",
    "ts-jest": "^29.4.6"
  },
  "dependencies": {
    "date-fns": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "next lint --fix",
      "jest --bail --findRelatedTests --passWithNoTests"
    ]
  }
}
